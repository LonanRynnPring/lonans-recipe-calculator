@page "/recipes/{Id}"
@inject AuthService Auth
@inject FirestoreService Firestore
@inject NavigationManager Nav

<PageTitle>@(recipe?.Name ?? "Recipe")</PageTitle>

@if (loading)
{
    <div class="text-center py-5">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Loading...</span>
        </div>
    </div>
}
else if (recipe == null)
{
    <div class="alert alert-warning">Recipe not found.</div>
    <a href="recipes" class="btn btn-secondary">&larr; Back to Recipes</a>
}
else if (editing)
{
    <div class="row justify-content-center">
        <div class="col-lg-7 col-md-9">
            <a href="recipes" class="text-muted text-decoration-none small">&larr; My Recipes</a>
            <h1 class="mt-1 mb-4">Edit Recipe</h1>

            @if (saveError != null)
            {
                <div class="alert alert-danger">@saveError</div>
            }

            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title mb-3">Recipe Details</h5>
                    <div class="mb-3">
                        <label class="form-label">Recipe Name</label>
                        <input @bind="editRecipe!.Name" @bind:event="oninput" class="form-control" />
                    </div>
                    <div class="mb-0">
                        <label class="form-label">Number of Servings</label>
                        <input @bind="editRecipe.Servings" type="number" step="0.5" min="0.5" class="form-control" />
                    </div>
                </div>
            </div>

            @if (editRecipe!.Ingredients.Count > 0)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <h6 class="mb-3">Ingredients</h6>
                        @for (int i = 0; i < editRecipe.Ingredients.Count; i++)
                        {
                            var index = i;
                            var ing = editRecipe.Ingredients[i];
                            <div class="border rounded p-2 mb-2">
                                <div class="d-flex align-items-center mb-2 gap-2">
                                    <input @bind="ing.Name" @bind:event="oninput" class="form-control form-control-sm flex-grow-1" placeholder="Name" />
                                    <button class="btn btn-outline-danger btn-sm" @onclick="() => editRecipe.Ingredients.RemoveAt(index)">Remove</button>
                                </div>
                                <div class="row g-2">
                                    <div class="col-sm-4">
                                        <label class="form-label small mb-1">Price</label>
                                        <div class="input-group input-group-sm">
                                            <span class="input-group-text">£</span>
                                            <input @bind="ing.PriceGBP" type="number" step="0.01" min="0" class="form-control" />
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <label class="form-label small mb-1">Package size</label>
                                        <div class="input-group input-group-sm">
                                            <input @bind="ing.PackageSize" type="number" step="1" min="0" class="form-control" />
                                            <select @bind="ing.Unit" class="form-select" style="max-width: 80px;">
                                                <option value="g">g</option>
                                                <option value="kg">kg</option>
                                                <option value="ml">ml</option>
                                                <option value="L">L</option>
                                                <option value="items">items</option>
                                                <option value="tsp">tsp</option>
                                                <option value="tbsp">tbsp</option>
                                            </select>
                                        </div>
                                    </div>
                                    <div class="col-sm-4">
                                        <label class="form-label small mb-1">Amount used</label>
                                        <div class="input-group input-group-sm">
                                            <input @bind="ing.AmountUsed" type="number" step="0.01" min="0" class="form-control" />
                                            <span class="input-group-text">@ing.Unit</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="text-end text-muted small mt-1">Cost: @ing.CostDisplay</div>
                            </div>
                        }
                        <div class="d-flex justify-content-between fw-bold mt-2">
                            <span>Total</span>
                            <span class="text-success">@editRecipe.TotalCostDisplay</span>
                        </div>
                        <div class="d-flex justify-content-between text-muted small">
                            <span>Per serving</span>
                            <span>@editRecipe.CostPerServingDisplay</span>
                        </div>
                    </div>
                </div>
            }

            <div class="card mb-3">
                <div class="card-body">
                    <h6 class="mb-3">Add Ingredient</h6>
                    <div class="mb-2">
                        <label class="form-label">Name</label>
                        <input @bind="newIngredient.Name" @bind:event="oninput" class="form-control" placeholder="e.g. Pasta" />
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Price</label>
                        <div class="input-group">
                            <span class="input-group-text">£</span>
                            <input @bind="newIngredient.PriceGBP" type="number" step="0.01" min="0" class="form-control" placeholder="e.g. 0.89" />
                        </div>
                    </div>
                    <div class="mb-2">
                        <label class="form-label">Package size</label>
                        <div class="input-group">
                            <input @bind="newIngredient.PackageSize" type="number" step="1" min="0" class="form-control" placeholder="e.g. 500" />
                            <select @bind="newIngredient.Unit" class="form-select" style="max-width: 110px;">
                                <option value="g">g</option>
                                <option value="kg">kg</option>
                                <option value="ml">ml</option>
                                <option value="L">L</option>
                                <option value="items">items</option>
                                <option value="tsp">tsp</option>
                                <option value="tbsp">tbsp</option>
                            </select>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Amount used in this recipe</label>
                        <div class="input-group">
                            <input @bind="newIngredient.AmountUsed" type="number" step="0.01" min="0" class="form-control" placeholder="e.g. 250" />
                            <span class="input-group-text">@newIngredient.Unit</span>
                        </div>
                    </div>
                    <button class="btn btn-outline-primary w-100" @onclick="AddNewIngredient" disabled="@(!CanAddNewIngredient)">
                        + Add Ingredient
                    </button>
                </div>
            </div>

            <div class="d-flex gap-2">
                <button class="btn btn-outline-secondary" @onclick="CancelEdit">Cancel</button>
                <button class="btn btn-success flex-grow-1" @onclick="SaveEdit"
                        disabled="@(string.IsNullOrWhiteSpace(editRecipe.Name) || editRecipe.Servings <= 0 || editRecipe.Ingredients.Count == 0 || saving)">
                    @(saving ? "Saving..." : "Save Changes")
                </button>
            </div>
        </div>
    </div>
}
else
{
    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <a href="recipes" class="text-muted text-decoration-none small">&larr; My Recipes</a>
            <h1 class="mt-1 mb-0">@recipe.Name</h1>
            <span class="text-muted">@recipe.Servings serving@(recipe.Servings == 1 ? "" : "s")</span>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm" @onclick="StartEdit">Edit</button>
            <button class="btn btn-outline-danger btn-sm" @onclick="ConfirmDelete" disabled="@deleting">
                @(deleting ? "Deleting..." : "Delete")
            </button>
        </div>
    </div>

    @if (confirmDelete)
    {
        <div class="alert alert-warning d-flex align-items-center gap-3 mb-4">
            <span>Delete <strong>@recipe.Name</strong>? This cannot be undone.</span>
            <button class="btn btn-danger btn-sm" @onclick="DeleteRecipe">Yes, delete</button>
            <button class="btn btn-secondary btn-sm" @onclick="() => confirmDelete = false">Cancel</button>
        </div>
    }

    <div class="row g-3 mb-4">
        <div class="col-sm-6">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted small">Total Cost</div>
                    <div class="fs-2 fw-bold text-success">@recipe.TotalCostDisplay</div>
                </div>
            </div>
        </div>
        <div class="col-sm-6">
            <div class="card text-center">
                <div class="card-body">
                    <div class="text-muted small">Cost Per Serving</div>
                    <div class="fs-2 fw-bold">@recipe.CostPerServingDisplay</div>
                </div>
            </div>
        </div>
    </div>

    <h5>Ingredient Breakdown</h5>
    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>Ingredient</th>
                    <th class="text-end">Price / pkg</th>
                    <th class="text-end">Amount used</th>
                    <th class="text-end">Cost</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var ing in recipe.Ingredients)
                {
                    <tr>
                        <td>@ing.Name</td>
                        <td class="text-end">£@ing.PriceGBP.ToString("0.00") / @ing.PackageSize @ing.Unit</td>
                        <td class="text-end">@ing.AmountUsed @ing.Unit</td>
                        <td class="text-end">@ing.CostDisplay</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr class="fw-bold table-light">
                    <td colspan="3">Total</td>
                    <td class="text-end text-success">@recipe.TotalCostDisplay</td>
                </tr>
            </tfoot>
        </table>
    </div>
}

@code {
    [Parameter] public string Id { get; set; } = "";

    private Recipe? recipe;
    private bool loading = true;
    private bool deleting;
    private bool confirmDelete;

    private bool editing;
    private Recipe? editRecipe;
    private Ingredient newIngredient = new();
    private bool saving;
    private string? saveError;

    private bool CanAddNewIngredient =>
        !string.IsNullOrWhiteSpace(newIngredient.Name) &&
        newIngredient.PriceGBP >= 0 &&
        newIngredient.PackageSize > 0 &&
        newIngredient.AmountUsed > 0;

    protected override async Task OnInitializedAsync()
    {
        await Auth.InitializeAsync();
        if (!Auth.IsAuthenticated)
        {
            Nav.NavigateTo("login", replace: true);
            return;
        }
        recipe = await Firestore.GetRecipeAsync(Id);
        loading = false;
    }

    private void StartEdit()
    {
        editRecipe = new Recipe
        {
            Id = recipe!.Id,
            Name = recipe.Name,
            Servings = recipe.Servings,
            CreatedAt = recipe.CreatedAt,
            Ingredients = recipe.Ingredients.Select(i => new Ingredient
            {
                Name = i.Name,
                PriceGBP = i.PriceGBP,
                PackageSize = i.PackageSize,
                Unit = i.Unit,
                AmountUsed = i.AmountUsed
            }).ToList()
        };
        newIngredient = new();
        saveError = null;
        editing = true;
    }

    private void CancelEdit()
    {
        editing = false;
        editRecipe = null;
    }

    private void AddNewIngredient()
    {
        if (!CanAddNewIngredient) return;
        editRecipe!.Ingredients.Add(new Ingredient
        {
            Name = newIngredient.Name.Trim(),
            PriceGBP = newIngredient.PriceGBP,
            PackageSize = newIngredient.PackageSize,
            Unit = newIngredient.Unit,
            AmountUsed = newIngredient.AmountUsed
        });
        newIngredient = new();
    }

    private async Task SaveEdit()
    {
        saving = true;
        saveError = null;
        var success = await Firestore.UpdateRecipeAsync(editRecipe!);
        if (success)
        {
            recipe = editRecipe;
            editing = false;
            editRecipe = null;
        }
        else
        {
            saveError = "Failed to save changes. Please try again.";
        }
        saving = false;
    }

    private void ConfirmDelete() => confirmDelete = true;

    private async Task DeleteRecipe()
    {
        deleting = true;
        await Firestore.DeleteRecipeAsync(Id);
        Nav.NavigateTo("recipes");
    }
}
